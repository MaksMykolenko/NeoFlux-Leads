# --- PostgreSQL ---
# App runtime: Supabase "Transaction pooler" (port 6543) or pooler host is fine.
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Prisma migrate / db push: must bypass session pooler (pool_size ~15) or you get:
#   FATAL: (EMAXCONNSESSION) max clients reached in session mode
# Use Supabase Dashboard → Settings → Database → "Direct connection"
# (host db.PROJECT_REF.supabase.co:5432), same password as pooled URL.
DIRECT_URL="postgresql://USER:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# --- Google Analytics 4 ---
# Measurement ID (public). Default in code: G-TYSXT9QGEC if unset.
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-TYSXT9QGEC"

# --- Public site URL (recommended on Vercel with a custom domain) ---
# Used for OAuth/logout redirects and metadata. Example: https://flux-leads.com
# (no trailing slash). If unset, the app falls back to x-forwarded-host / req.url.
NEXT_PUBLIC_SITE_URL=""

# --- Google Gemini ---
# API key for Gemini (local niche+city search, universal/beats search, AI letters).
# https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# --- Flux ID (OAuth 2.0) ---
# Identity provider for the Flux ecosystem. Register your client by running on
# the Flux ID server:
#   php oauth/register_client.php "NeoFlux Lead Engine" "http://localhost:3000/api/auth/flux/callback"
# The command outputs client_id + client_secret (the secret is shown ONCE).
FLUX_ID_BASE_URL="https://fluxid.fluxmarketplace.store"
FLUX_CLIENT_ID=""
FLUX_CLIENT_SECRET=""
# Must match the redirect_uri registered for this OAuth client (local vs prod).
# Production example: https://flux-leads.com/api/auth/flux/callback
FLUX_REDIRECT_URI="http://localhost:3000/api/auth/flux/callback"
# Random 32+ byte secret for signing the OAuth state cookie. Generate with:
#   openssl rand -base64 48
FLUX_OAUTH_STATE_SECRET=""

# --- Admin / RBAC ---
# Email власника платформи. Юзер з цим email при першому вході через Flux ID
# отримує роль OWNER (єдина роль, що може назначати ADMIN/OWNER іншим).
# Кожному наступному входу OWNER теж примусово підтверджується.
OWNER_EMAIL=""

# --- Platform SMTP (Простий режим відправки) ---
# Центральний SMTP-акаунт платформи. Використовується, коли юзер вибрав
# "Простий режим" (User.usePlatformSmtp=true) і не підключив власний SMTP.
# Лист буде з адреси PLATFORM_SMTP_FROM_EMAIL, а юзерський fromEmail
# проставляється у Reply-To, щоб відповіді клієнтів приходили йому.
# Без цих змінних Простий режим повертає PLATFORM_NOT_CONFIGURED при send.
PLATFORM_SMTP_HOST="smtp.hostinger.com"
PLATFORM_SMTP_PORT="465"
PLATFORM_SMTP_USER=""
PLATFORM_SMTP_PASS=""
PLATFORM_SMTP_FROM_EMAIL=""

# --- Encryption (AES-256-GCM для секретів юзера у БД, SMTP паролі) ---
# 32-байтовий ключ у hex (64 символи). Згенерувати:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ЯКЩО загубите ключ — усі зашифровані smtpPass стануть нерозшифровуваними.
ENCRYPTION_KEY=""

# --- Stripe (підписки через Checkout) ---
# Test mode key (sk_test_*) для розробки, live (sk_live_*) для прода.
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
# Секрет для верифікації Stripe webhook-підпису (whsec_*).
# Локально: `stripe listen --forward-to localhost:3000/api/webhook/stripe`
# покаже значення на старті. У production: створіть endpoint у
# https://dashboard.stripe.com/webhooks і візьміть signing secret з нього.
STRIPE_WEBHOOK_SECRET=""
# Базовий URL продакшну для success_url / cancel_url Stripe Checkout.
# Не співпадає з NEXT_PUBLIC_SITE_URL семантично, але часто = тому ж значенню.
NEXT_PUBLIC_BASE_URL="https://flux-leads.com"
