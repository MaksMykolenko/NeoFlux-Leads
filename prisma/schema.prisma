generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Моделі ---

enum LeadMode {
  LOCAL // Local-business leads (niche + city via AI web search + website audit pipeline)
  BEATS // Music artists (potential beat buyers — handles, platforms, followers)
  UNIVERSAL // Free-form OSINT-style leads (Gemini + Google Search grounding)
}

model Lead {
  id               String   @id @default(uuid())
  mode             LeadMode @default(LOCAL)
  // Власник ліда. Кожен юзер бачить тільки СВОЇ ліди — це поле обов'язкове
  // для всіх лідів, створених після запуску мульти-юзера. Старі (pre-auth)
  // ліди мають NULL і не з'являються в жодному запиті.
  userId           String?
  companyName      String // For BEATS this stores the artist handle, e.g. "@youngluna.beats"
  realName         String? // BEATS-only: real / stage name behind the handle
  website          String?
  email            String?
  phone            String?
  city             String?
  category         String? // LOCAL: business niche. BEATS: genre tags ("Trap / Drill")
  source           String? // LOCAL: e.g. "Web search (AI)". BEATS: "SoundCloud" / "YouTube" / "Instagram"
  followers        Int? // BEATS-only audience size
  lookingForType   Boolean? // BEATS-only — is the artist publicly seeking type beats?
  socialLinks      Json? // BEATS-only: { instagram, soundcloud, youtube, tiktok, twitter, spotify, beatstars, discord, telegram, website }
  painPoints       String[] @default([])
  hasOnlineBooking Boolean  @default(false)
  score            Int      @default(0) // Opportunity Scoring (0-100)
  status           String   @default("New") // New, Qualified, Contacted, Replied, Won, Lost
  // Стан Autopilot pipeline (окремий від CRM-status). Cron-кроки фільтрують ліди
  // саме по цьому полю. Значення: NEW | PENDING_AUDIT | PENDING_GENERATION |
  // PENDING_DELIVERY | PROCESSED. Default NEW = лід ще не у конвеєрі.
  pipelineStatus   String   @default("NEW")
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Зв'язки
  user     User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  audit    Audit?
  messages Message[]

  @@index([userId])
  @@index([pipelineStatus, userId])
}

model Audit {
  id               String   @id @default(uuid())
  leadId           String   @unique
  mobileFriendly   Boolean  @default(false)
  hasSSL           Boolean  @default(false)
  performanceScore Int? // Оцінка швидкості
  issues           String[] // Список знайдених проблем
  summary          String?  @db.Text // AI-згенерований висновок
  createdAt        DateTime @default(now())

  // Зв'язки
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Message {
  id             String   @id @default(uuid())
  leadId         String
  subject        String
  body           String   @db.Text
  sentAt         DateTime @default(now())
  replyStatus    String   @default("No Reply") // No Reply, Replied, Bounced
  attachment     Json? // BEATS-only: { name, bytes, bpm, keySig, genre, price }
  channels       Json? // BEATS-only outreach: ["email", "instagram", "telegram", ...] — channels the user actually opened to send through
  // Стан реальної доставки через BYOSMTP. DRAFT = тільки збережено в CRM,
  // не відправлено. SENT = успішно відправлено. FAILED = nodemailer повернув
  // помилку (див. errorLog).
  deliveryStatus String   @default("DRAFT") // DRAFT | SENT | FAILED
  errorLog       String?  @db.Text // повний текст помилки SMTP

  // Зв'язки
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

// Юзер, який увійшов через Flux ID. Локальна копія профілю — оновлюється при кожному вході.
model User {
  id          String   @id @default(uuid())
  fluxUserId  Int      @unique // sub з Flux ID userinfo
  email       String?  @unique
  username    String?
  displayName String?
  avatarUrl   String?  @db.Text
  // RBAC: USER (default) | ADMIN | OWNER. OWNER призначається автоматично за
  // email-у з env OWNER_EMAIL при першому вході. Тільки OWNER може змінювати
  // ролі інших юзерів. Див. src/lib/admin.ts.
  role        String   @default("USER")
  accountType String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Підписка / тарифний план
  plan                String   @default("STARTER") // STARTER | PRO | AGENCY (див. src/lib/subscription.ts)
  leadsProcessedCount Int      @default(0) // лічильник місячного скрапінгу
  planResetDate       DateTime @default(now()) // коли востаннє скидали лічильник

  // Stripe billing. Customer створюється на першому Checkout, Subscription —
  // після успішної оплати. Обидва поля унікальні: один Stripe-об'єкт ↔ один юзер.
  // Видалення підписки (cancel) обнуляє лише stripeSubscriptionId, customer
  // залишається — щоб юзер міг купити знову без створення нового Customer.
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  // Гібридна email-модель.
  //   true  → "Простий режим" (рекомендовано): листи йдуть через центральний
  //           PLATFORM_SMTP_* акаунт. У заголовку From: підставляємо платформну
  //           адресу, а Reply-To = fromEmail юзера, щоб відповіді приходили
  //           прямо йому в інбокс.
  //   false → "Розширений режим": BYOSMTP, тобто відправка через
  //           smtpHost/smtpPort/smtpUser/smtpPass юзера нижче.
  // Дефолт true — щоб нові юзери одразу могли слати без налаштування SMTP.
  // Існуючим юзерам після міграції рекомендовано виконати:
  //   UPDATE "User" SET "usePlatformSmtp" = false WHERE "smtpHost" IS NOT NULL;
  usePlatformSmtp Boolean @default(true)

  // BYOSMTP: користувач підключає власний поштовий сервер для відправки.
  // smtpPass зашифрований AES-256-GCM з ключем ENCRYPTION_KEY (src/lib/crypto.ts).
  // Записи зі старим plaintext продовжать працювати завдяки fallback у decrypt().
  smtpHost  String?
  smtpPort  Int?
  smtpUser  String?
  smtpPass  String?
  fromEmail String?
  fromName  String?

  sessions         Session[]
  leads            Lead[]
  telegramSession  TelegramSession?
  autopilotConfigs AutopilotConfig[]
}

model Session {
  id        String   @id @default(uuid())
  // SHA-256 hash значення cookie. Сирий токен ніколи не зберігається в БД.
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  userAgent String?  @db.Text
  ip        String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// Журнал дій адмінів. Кожна зміна плану/ролі юзера, ручне втручання тощо
// фіксується тут — щоб у спорах було видно, хто і коли що змінив.
model AuditLog {
  id           String   @id @default(uuid())
  action       String // напр. "USER_PLAN_CHANGED", "USER_ROLE_CHANGED"
  adminId      String
  targetUserId String?
  metadata     Json? // { from: "STARTER", to: "PRO", ... }
  timestamp    DateTime @default(now())

  @@index([adminId])
  @@index([targetUserId])
  @@index([timestamp])
}

// Telegram MTProto userbot сесія. Один юзер ↔ одна авторизація (мобільний номер).
// `sessionKey` зберігаємо зашифрованим AES-256-GCM через src/lib/crypto.ts,
// тож дамп БД не дозволяє отримати доступ до Telegram акаунта.
// dailyCount / lastReset — для anti-spam rate-limit (Autopilot delivery).
model TelegramSession {
  id         String   @id @default(uuid())
  userId     String   @unique
  phone      String
  sessionKey String   @db.Text
  isActive   Boolean  @default(true)
  dailyCount Int      @default(0)
  lastReset  DateTime @default(now())
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Конфіг Autopilot — повторюваний пошук + outreach за розкладом cron.
// Один юзер може мати кілька конфігів (різні ніші/регіони/мови).
// `channels` — масив рядків: ["email"], ["telegram"], або обидва.
// `mode` повторно використовує існуючий enum LeadMode.
model AutopilotConfig {
  id             String   @id @default(uuid())
  userId         String
  mode           LeadMode
  searchQuery    String
  targetRegion   String?
  outputLanguage String   @default("English")
  channels       String[] @default([])
  maxLeadsPerDay Int      @default(10)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([isActive])
}
